        <mxCell id="t_DKb6i7VvN18Yv3edmi-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Useful for peak booking days" vertex="1">
