        <mxCell id="5BOf5oXSLcgK6-mnbLjW-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="design a whatsapp system with following requirements:&lt;div&gt;1. usr service&lt;/div&gt;&lt;div&gt;2. chat service&amp;nbsp;&lt;/div&gt;&lt;div&gt;3. group service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;optimize the chat service for handling the millions of requests&lt;/div&gt;&lt;div&gt;specify the type of connection used in the design&lt;/div&gt;&lt;div&gt;determine how the design will be done fo last seen functionality&lt;/div&gt;&lt;div&gt;implement&amp;nbsp; cdc pipeline in the same architecture&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="350" x="10" y="60" as="geometry" />
        </mxCell>
        <mxCell id="5BOf5oXSLcgK6-mnbLjW-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Functional requirements" vertex="1">
