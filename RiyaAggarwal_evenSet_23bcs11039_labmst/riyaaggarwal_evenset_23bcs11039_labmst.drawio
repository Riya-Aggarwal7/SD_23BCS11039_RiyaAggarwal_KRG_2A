        </mxCell>
        <mxCell id="5BOf5oXSLcgK6-mnbLjW-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="1. user should be able to register and login to the&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;application&lt;div&gt;2. client should be able to make groups in the application&lt;/div&gt;&lt;div&gt;3. client should be able to send messages to another user&lt;/div&gt;&lt;div&gt;4. client should be able to see previous chats&lt;/div&gt;&lt;div&gt;5. client should be able to see the last seen of other users&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="320" x="-50" y="320" as="geometry" />
        </mxCell>
