        <mxCell id="5BOf5oXSLcgK6-mnbLjW-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Even set" vertex="1">
