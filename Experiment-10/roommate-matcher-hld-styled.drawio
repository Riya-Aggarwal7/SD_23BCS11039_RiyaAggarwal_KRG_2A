        <mxCell id="LZzTBMvUempXx9omUjw9-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Local File Store&lt;/b&gt;" vertex="1">
