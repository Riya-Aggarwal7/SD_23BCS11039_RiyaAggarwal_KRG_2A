<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36">
  <diagram name="Page-1" id="roommate-matcher-hld">
    <mxGraphModel dx="2284" dy="1598" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;PG / Hostel Roommate Matcher&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="350" x="234" y="-180" as="geometry" />
        </mxCell>
        <mxCell id="fr-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Functional Requirements&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="220" x="130" y="-140" as="geometry" />
        </mxCell>
        <mxCell id="fr-body" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font size=&quot;3&quot;&gt;1. User should be able to register and login securely (role-based: USER / ADMIN)&lt;/font&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;2. User should be able to build a comprehensive profile (budget, sleep time, cleanliness, diet, etc.)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;3. User should be able to view ranked roommate matches based on a 100-point compatibility score&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;4. User should be able to send, accept, reject, or cancel roommate requests to matched peers&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="580" x="119" y="-60" as="geometry" />
        </mxCell>
        <mxCell id="nfr-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Non-Functional Requirements&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="260" x="105" y="120" as="geometry" />
        </mxCell>
        <mxCell id="nfr-body" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font size=&quot;3&quot;&gt;1. Security: BCrypt password encryption; Spring Security with role-based access control (USER/ADMIN)&lt;/font&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;2. Scalability: Stateless MVC design; JPA repositories with PostgreSQL for durable persistence&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;3. Consistency: Profile and request data are strongly consistent via transactional relational DB&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="580" x="110" y="200" as="geometry" />
        </mxCell>
        <mxCell id="ce-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Core Entities&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="150" x="110" y="340" as="geometry" />
        </mxCell>
        <mxCell id="ce-body" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font size=&quot;3&quot;&gt;1. User (id, name, email, password, phone, gender, role, createdAt)&lt;/font&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;2. Profile (user_id FK, age, city, budget, sleepTime, wakeTime, cleanliness, smoking, foodPreference, bio, imagePath)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;3. RoommateRequest (sender_id FK, receiver_id FK, status: PENDING/ACCEPTED/REJECTED/CANCELLED)&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="580" x="100" y="420" as="geometry" />
        </mxCell>
        <mxCell id="api-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;API Endpoints&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="160" x="110" y="540" as="geometry" />
        </mxCell>
        <mxCell id="api-body" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font size=&quot;3&quot;&gt;1. GET &amp;nbsp;/ &amp;nbsp;→ Landing page (public)&lt;/font&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;2. GET/POST /register &amp;nbsp;→ User registration&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;3. GET/POST /login &amp;nbsp;→ Spring Security form login&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;4. GET/POST /profile/edit &amp;nbsp;→ Build or update lifestyle profile&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;5. GET /matches?gender={g}&amp;amp;maxBudget={b}&amp;amp;city={c} &amp;nbsp;→ Ranked match list&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;6. POST /request/send &amp;nbsp;→ Send roommate request (body: receiverId)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;7. POST /request/accept | /request/reject | /request/cancel (body: requestId)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;8. GET /admin/dashboard &amp;nbsp;→ Admin-only: user stats (total users, profiles, requests)&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="650" x="100" y="600" as="geometry" />
        </mxCell>
        <mxCell id="hld-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;High Level Design&lt;/b&gt;" vertex="1">
